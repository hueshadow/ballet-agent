.tab-bar {
  display: flex;
  align-items: center;
  justify-content: space-around;
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background: #fff;
  border-top: 1rpx solid #e5e5e5;
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 999;
}

.tab-bar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
}

.tab-text {
  font-size: 20rpx;
  color: #999;
  margin-top: 4rpx;
  letter-spacing: 0.5rpx;
}

.tab-bar-item.active .tab-text {
  color: #000;
  font-weight: 500;
}

/* 图标基础样式 */
.icon {
  width: 44rpx;
  height: 44rpx;
  position: relative;
}

/* 简约线条图标 —— 用 CSS 绘制 */
.icon-home::before {
  content: '';
  display: block;
  width: 20rpx;
  height: 16rpx;
  border: 3rpx solid #999;
  border-top: none;
  position: absolute;
  bottom: 4rpx;
  left: 50%;
  transform: translateX(-50%);
}
.icon-home::after {
  content: '';
  display: block;
  width: 0;
  height: 0;
  border-left: 16rpx solid transparent;
  border-right: 16rpx solid transparent;
  border-bottom: 12rpx solid #999;
  position: absolute;
  top: 4rpx;
  left: 50%;
  transform: translateX(-50%);
}
.icon-home.icon-active::before { border-color: #000; }
.icon-home.icon-active::after { border-bottom-color: #000; }

.icon-list::before {
  content: '';
  display: block;
  width: 24rpx;
  height: 0;
  border-top: 3rpx solid #999;
  border-bottom: 3rpx solid #999;
  padding-top: 6rpx;
  position: absolute;
  top: 10rpx;
  left: 50%;
  transform: translateX(-50%);
}
.icon-list::after {
  content: '';
  display: block;
  width: 24rpx;
  height: 0;
  border-top: 3rpx solid #999;
  position: absolute;
  bottom: 10rpx;
  left: 50%;
  transform: translateX(-50%);
}
.icon-list.icon-active::before { border-color: #000; }
.icon-list.icon-active::after { border-color: #000; }

.icon-video::before {
  content: '';
  display: block;
  width: 24rpx;
  height: 18rpx;
  border: 3rpx solid #999;
  border-radius: 4rpx;
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
}
.icon-video.icon-active::before { border-color: #000; }

.icon-profile::before {
  content: '';
  display: block;
  width: 14rpx;
  height: 14rpx;
  border: 3rpx solid #999;
  border-radius: 50%;
  position: absolute;
  top: 4rpx;
  left: 50%;
  transform: translateX(-50%);
}
.icon-profile::after {
  content: '';
  display: block;
  width: 24rpx;
  height: 10rpx;
  border: 3rpx solid #999;
  border-bottom: none;
  border-radius: 12rpx 12rpx 0 0;
  position: absolute;
  bottom: 6rpx;
  left: 50%;
  transform: translateX(-50%);
}
.icon-profile.icon-active::before { border-color: #000; }
.icon-profile.icon-active::after { border-color: #000; }

/* 中间 + 号按钮 */
.center-btn {
  width: 88rpx;
  height: 88rpx;
  background: #000;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: -40rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
}

.plus-icon {
  color: #fff;
  font-size: 44rpx;
  font-weight: 300;
  line-height: 1;
  margin-top: -4rpx;
}
