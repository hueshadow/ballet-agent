.tab-bar {
  display: flex;
  align-items: center;
  justify-content: space-around;
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 110rpx;
  background: #fbf8f1;
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 999;
  box-shadow: 0 -4rpx 24rpx rgba(35, 28, 16, 0.06);
}

/* 顶部金色细线 + 居中钻石装饰 */
.tab-bar::before {
  content: '';
  position: absolute;
  top: 0;
  left: 24rpx;
  right: 24rpx;
  height: 1rpx;
  background: linear-gradient(90deg,
    transparent 0%,
    #b89968 20%,
    #d4b57f 50%,
    #b89968 80%,
    transparent 100%);
}

.tab-bar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
  position: relative;
  transition: transform 250ms cubic-bezier(0.32, 0.72, 0.36, 1);
}

.tab-bar-item.active::after {
  content: '';
  position: absolute;
  top: 6rpx;
  left: 50%;
  transform: translateX(-50%) rotate(45deg);
  width: 6rpx;
  height: 6rpx;
  background: #b89968;
}

.tab-text {
  font-size: 20rpx;
  color: #8c8472;
  margin-top: 6rpx;
  letter-spacing: 2rpx;
}

.tab-bar-item.active .tab-text {
  color: #b89968;
  font-weight: 500;
}

/* ============================================
   Art Deco 芭蕾元素图标 (SVG Mask)
   ============================================ */

@-webkit-keyframes iconPop {
  0% { -webkit-transform: scale(0.8) translateY(2rpx); transform: scale(0.8) translateY(2rpx); }
  50% { -webkit-transform: scale(1.15) translateY(-4rpx); transform: scale(1.15) translateY(-4rpx); }
  100% { -webkit-transform: scale(1) translateY(0); transform: scale(1) translateY(0); }
}

@keyframes iconPop {
  0% { -webkit-transform: scale(0.8) translateY(2rpx); transform: scale(0.8) translateY(2rpx); }
  50% { -webkit-transform: scale(1.15) translateY(-4rpx); transform: scale(1.15) translateY(-4rpx); }
  100% { -webkit-transform: scale(1) translateY(0); transform: scale(1) translateY(0); }
}

.icon {
  width: 48rpx;
  height: 48rpx;
  background-color: #8c8472;
  -webkit-mask-size: contain;
  -webkit-mask-repeat: no-repeat;
  -webkit-mask-position: center;
  transition: background-color 250ms ease, transform 200ms ease;
  transform-origin: bottom center;
}

.icon.icon-active {
  background-color: #b89968;
  -webkit-animation: iconPop 400ms cubic-bezier(0.32, 0.72, 0.36, 1) forwards;
  animation: iconPop 400ms cubic-bezier(0.32, 0.72, 0.36, 1) forwards;
}

/* 按钮点击时的即时压低反馈 */
.tab-hover .icon {
  transform: scale(0.85) translateY(4rpx) !important;
  opacity: 0.8;
}
.tab-hover .tab-text {
  opacity: 0.8;
}
.tab-hover.center .center-btn {
  transform: scale(0.92);
  opacity: 0.9;
}

