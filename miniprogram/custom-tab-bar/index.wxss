/* 中间 + 号按钮 · 香槟金圆 */
.center-btn {
  width: 96rpx;
  height: 96rpx;
  background:
    radial-gradient(circle at 30% 30%,
      #e6d4ad 0%,
      #d4b57f 35%,
      #b89968 70%,
      #8c6f3f 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: -48rpx;
  box-shadow:
    0 8rpx 20rpx rgba(140, 111, 63, 0.35),
    inset 0 0 0 2rpx rgba(255, 255, 255, 0.2);
  position: relative;
}
.center-btn::before {
  content: '';
  position: absolute;
  inset: 6rpx;
  border-radius: 50%;
  border: 1rpx solid rgba(251, 248, 241, 0.4);
}

.plus-icon {
  color: #131826;
  font-size: 48rpx;
  font-weight: 200;
  line-height: 1;
  margin-top: -4rpx;
}
