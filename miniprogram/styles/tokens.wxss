/* ============================================
   芭蕾管家 · 设计 Token
   风格：Art Deco / Elegant Modern
   墨蓝 × 象牙白 × 香槟金
   ============================================ */

page {
  /* ---- 颜色 · 背景 ---- */
  --color-bg-primary: #fbf8f1;          /* 象牙米白 */
  --color-bg-secondary: #f3ede0;        /* 暖米色 */
  --color-bg-tertiary: #e8dcc4;         /* 深米色 */
  --color-bg-paper: #ffffff;            /* 纯白卡纸 */
  --color-bg-noir: #131826;             /* 墨夜蓝 */

  /* ---- 颜色 · 文字 ---- */
  --color-text-primary: #131826;        /* 墨夜蓝 */
  --color-text-secondary: #4a5063;      /* 中性蓝灰 */
  --color-text-tertiary: #8c8472;       /* 暖灰 */
  --color-text-inverse: #fbf8f1;        /* 反白（米色） */
  --color-text-muted: #b3a98e;          /* 沙金灰 */

  /* ---- 颜色 · 金色系（Art Deco 灵魂） ---- */
  --color-gold: #b89968;                /* 香槟金主色 */
  --color-gold-light: #d4b57f;          /* 浅金 */
  --color-gold-deep: #8c6f3f;           /* 深金 */
  --color-gold-soft: #e6d4ad;           /* 柔金 */

  /* 香槟金渐变（按钮/数字高光） */
  --gradient-gold: linear-gradient(135deg, #d4b57f 0%, #b89968 50%, #8c6f3f 100%);
  /* 镜面金（细线/分割） */
  --gradient-gold-line: linear-gradient(90deg,
    transparent 0%,
    var(--color-gold) 20%,
    var(--color-gold-light) 50%,
    var(--color-gold) 80%,
    transparent 100%);

  /* ---- 颜色 · 边框 ---- */
  --color-border: #d8ccb0;              /* 米色边框 */
  --color-border-light: #ece4d2;        /* 浅米色边框 */
  --color-border-gold: #c9a876;         /* 金色细边 */

  /* ---- 颜色 · 强调（保留兼容） ---- */
  --color-accent: #131826;              /* 墨夜蓝（主按钮等） */
  --color-accent-soft: #2a304a;

  /* ---- 颜色 · 状态 ---- */
  --color-success: #6b8e5a;             /* 沉静橄榄绿 */
  --color-warning: #c8943c;             /* 琥珀 */
  --color-error: #b04848;               /* 沉静朱红 */

  /* ---- 字体栈 ---- */
  --font-family-sans:
    -apple-system, BlinkMacSystemFont, 'Helvetica Neue',
    'PingFang SC', 'Microsoft YaHei', sans-serif;
  --font-family-serif:
    'Didot', 'Bodoni 72', 'Songti SC', 'STSong',
    'Noto Serif CJK SC', 'Noto Serif SC', Georgia, serif;
  --font-family-display: var(--font-family-serif);

  /* ---- 字号 ---- */
  --font-size-xs: 22rpx;
  --font-size-sm: 24rpx;
  --font-size-base: 28rpx;
  --font-size-md: 30rpx;
  --font-size-lg: 34rpx;
  --font-size-xl: 40rpx;
  --font-size-2xl: 52rpx;
  --font-size-3xl: 80rpx;
  --font-size-display: 120rpx;          /* 巨型展示数字 */

  /* ---- 字重 ---- */
  --font-weight-light: 300;
  --font-weight-normal: 400;
  --font-weight-medium: 500;
  --font-weight-semibold: 600;
  --font-weight-bold: 700;

  /* ---- 字距 ---- */
  --tracking-tight: -1rpx;
  --tracking-normal: 0;
  --tracking-wide: 2rpx;
  --tracking-wider: 6rpx;               /* Art Deco 标志性宽字距 */
  --tracking-widest: 10rpx;

  /* ---- 间距 ---- */
  --spacing-xs: 8rpx;
  --spacing-sm: 16rpx;
  --spacing-md: 24rpx;
  --spacing-lg: 32rpx;
  --spacing-xl: 48rpx;
  --spacing-2xl: 64rpx;
  --spacing-3xl: 96rpx;

  /* ---- 圆角（Art Deco 偏方正，只在按钮/标签用小圆角） ---- */
  --radius-sm: 4rpx;
  --radius-md: 8rpx;
  --radius-lg: 12rpx;
  --radius-pill: 9999rpx;
  --radius-full: 9999rpx;               /* 兼容旧引用 */

  /* ---- 阴影（柔和、有暖色调） ---- */
  --shadow-sm: 0 2rpx 8rpx rgba(35, 28, 16, 0.04);
  --shadow-md: 0 6rpx 24rpx rgba(35, 28, 16, 0.06);
  --shadow-lg: 0 12rpx 48rpx rgba(35, 28, 16, 0.08);
  --shadow-gold: 0 6rpx 20rpx rgba(184, 153, 104, 0.25);

  /* ---- 动画 ---- */
  --duration-fast: 150ms;
  --duration-normal: 250ms;
  --duration-slow: 400ms;
  --ease-out: cubic-bezier(0.25, 0.46, 0.45, 0.94);
  --ease-elegant: cubic-bezier(0.32, 0.72, 0.36, 1);
}
