<view class="page">
  <view class="header-row">
    <text class="page-title">机构管理</text>
    <view class="add-btn" bindtap="onAdd">
      <text class="add-text">+ 新建</text>
    </view>
  </view>

  <!-- 列表 -->
  <view class="list" wx:if="{{studios.length > 0}}">
    <view class="list-item" wx:for="{{studios}}" wx:key="_id">
      <view class="item-info" bindtap="onEdit" data-id="{{item._id}}">
        <text class="item-name">{{item.name}}</text>
        <text class="item-sub" wx:if="{{item.city}}">{{item.city}}</text>
      </view>
      <view class="item-actions">
        <text class="action-edit" bindtap="onEdit" data-id="{{item._id}}">编辑</text>
        <text class="action-delete" bindtap="onDelete" data-id="{{item._id}}" data-name="{{item.name}}">删除</text>
      </view>
    </view>
  </view>

  <!-- 空态 -->
  <view class="empty-state" wx:if="{{loaded && studios.length === 0}}">
    <text class="empty-text">还没有添加机构</text>
    <text class="empty-hint">添加你常去的芭蕾工作室</text>
  </view>
</view>
