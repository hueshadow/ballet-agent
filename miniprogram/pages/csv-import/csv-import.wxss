@import '/styles/tokens.wxss';

.page { padding: 32rpx; }

.page-title {
  display: block;
  font-size: var(--font-size-xl);
  font-weight: var(--font-weight-semibold);
  margin-bottom: 40rpx;
}

/* 步骤 */
.step {
  display: flex;
  gap: 24rpx;
  margin-bottom: 40rpx;
}

.step-num {
  width: 48rpx;
  height: 48rpx;
  background: var(--color-accent);
  color: var(--color-text-inverse);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-semibold);
  flex-shrink: 0;
  line-height: 48rpx;
  text-align: center;
}

.step-content { flex: 1; }

.step-title {
  display: block;
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-medium);
  margin-bottom: 8rpx;
}

.step-desc {
  display: block;
  font-size: var(--font-size-sm);
  color: var(--color-text-tertiary);
  margin-bottom: 16rpx;
}

.step-btn {
  display: inline-block;
  padding: 12rpx 32rpx;
  border: 1rpx solid var(--color-accent);
  border-radius: var(--radius-full);
}

.step-btn-text {
  font-size: var(--font-size-sm);
  color: var(--color-accent);
}

.tip {
  padding: 24rpx;
  background: var(--color-bg-secondary);
  border-radius: var(--radius-md);
}

.tip-text {
  display: block;
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
  line-height: 1.8;
}

/* 预览 */
.preview-summary {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.summary-text {
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-medium);
}

.summary-error {
  font-size: var(--font-size-sm);
  color: var(--color-error);
}

.preview-item {
  display: flex;
  gap: 16rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--color-border-light);
  font-size: var(--font-size-sm);
}

.item-error { color: var(--color-error); }

.preview-row { color: var(--color-text-tertiary); width: 60rpx; }
.preview-date { color: var(--color-text-secondary); width: 160rpx; }
.preview-studio, .preview-teacher, .preview-type { flex: 1; }

.preview-more {
  padding: 16rpx 0;
  text-align: center;
}

.more-text {
  font-size: var(--font-size-sm);
  color: var(--color-text-tertiary);
}

.error-list {
  margin-top: 24rpx;
  padding: 20rpx;
  background: #fff5f5;
  border-radius: var(--radius-md);
  margin-bottom: 24rpx;
}

.error-title {
  display: block;
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-medium);
  color: var(--color-error);
  margin-bottom: 12rpx;
}

.error-item {
  font-size: var(--font-size-xs);
  color: var(--color-error);
  margin-bottom: 8rpx;
}

/* 进度 */
.progress-section {
  padding-top: 200rpx;
  text-align: center;
}

.progress-text {
  display: block;
  font-size: var(--font-size-base);
  margin-bottom: 24rpx;
}

.progress-bar {
  height: 12rpx;
  background: var(--color-bg-secondary);
  border-radius: var(--radius-full);
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: var(--color-accent);
  border-radius: var(--radius-full);
  transition: width 0.3s;
}
