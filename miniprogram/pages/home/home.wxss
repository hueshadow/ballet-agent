@import '/styles/tokens.wxss';

.page {
  padding: 32rpx 32rpx calc(160rpx + env(safe-area-inset-bottom));
  background: var(--color-bg-primary);
  min-height: 100vh;
}

/* ===== Hero · 标题区 ===== */
.hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 0 48rpx;
}

.hero-eyebrow {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}
.hero-line {
  width: 80rpx;
  height: 1rpx;
  background: var(--gradient-gold-line);
}
.hero-eyebrow-text {
  font-size: 20rpx;
  letter-spacing: var(--tracking-widest);
  color: var(--color-gold-deep);
  font-weight: var(--font-weight-medium);
}
.hero-title {
  font-family: var(--font-family-serif);
  font-size: 60rpx;
  font-weight: var(--font-weight-light);
  color: var(--color-text-primary);
  letter-spacing: var(--tracking-wider);
  line-height: 1.1;
}
.hero-sub {
  margin-top: 16rpx;
  font-family: var(--font-family-serif);
  font-style: italic;
  font-size: var(--font-size-sm);
  color: var(--color-gold-deep);
  letter-spacing: var(--tracking-wide);
}

/* ===== 核心指标卡片 ===== */
.stat-cards {
  display: flex;
  gap: 20rpx;
  margin-bottom: 48rpx;
}
.stat-card {
  position: relative;
  flex: 1;
  padding: 40rpx 28rpx 32rpx;
  background: var(--color-bg-paper);
  border: 1rpx solid var(--color-border-light);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-sm);
  overflow: hidden;
}
.stat-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 24rpx;
  right: 24rpx;
  height: 1rpx;
  background: var(--gradient-gold-line);
}
.stat-corner {
  position: absolute;
  width: 24rpx;
  height: 24rpx;
  pointer-events: none;
}
.stat-corner-tl {
  top: 10rpx;
  left: 10rpx;
  border-top: 1rpx solid var(--color-gold);
  border-left: 1rpx solid var(--color-gold);
}
.stat-corner-br {
  bottom: 10rpx;
  right: 10rpx;
  border-bottom: 1rpx solid var(--color-gold);
  border-right: 1rpx solid var(--color-gold);
}

.stat-eyebrow {
  display: block;
  font-size: 20rpx;
  letter-spacing: var(--tracking-widest);
  color: var(--color-gold-deep);
  text-transform: uppercase;
  font-weight: var(--font-weight-medium);
  margin-bottom: 16rpx;
}

.stat-num-row {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}
.stat-number {
  font-family: var(--font-family-serif);
  font-size: 96rpx;
  font-weight: var(--font-weight-light);
  color: var(--color-text-primary);
  letter-spacing: var(--tracking-tight);
  line-height: 1;
}
.stat-unit {
  font-family: var(--font-family-serif);
  font-size: var(--font-size-md);
  color: var(--color-gold-deep);
  font-style: italic;
}

.stat-sub {
  display: block;
  margin-top: 12rpx;
  font-size: var(--font-size-sm);
  color: var(--color-text-tertiary);
  letter-spacing: var(--tracking-wide);
}

/* ===== 本周进度 ===== */
.week-section {
  margin-bottom: 48rpx;
  padding: 32rpx 36rpx;
  background: var(--color-bg-paper);
  border: 1rpx solid var(--color-border-light);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-sm);
}

.week-header {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin-bottom: 20rpx;
}

.week-title {
  font-size: 22rpx;
  letter-spacing: var(--tracking-widest);
  color: var(--color-gold-deep);
  text-transform: uppercase;
  font-weight: var(--font-weight-medium);
}

.week-count {
  font-family: var(--font-family-serif);
  font-size: var(--font-size-md);
  color: var(--color-text-primary);
  letter-spacing: var(--tracking-wide);
}

.progress-track {
  position: relative;
  height: 8rpx;
  background: var(--color-bg-secondary);
  border-radius: var(--radius-pill);
  overflow: hidden;
}
.progress-fill {
  height: 100%;
  background: var(--gradient-gold);
  border-radius: var(--radius-pill);
  transition: width 0.6s var(--ease-elegant);
  box-shadow: 0 0 12rpx rgba(212, 181, 127, 0.5);
}

/* ===== 最近课时 ===== */
.last-lesson {
  margin-bottom: 56rpx;
  text-align: center;
}
.last-text {
  font-family: var(--font-family-serif);
  font-style: italic;
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  letter-spacing: var(--tracking-wide);
}

/* ===== 里程碑 ===== */
.milestone-section { margin-bottom: 48rpx; }

.milestone-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 28rpx;
}

.milestone {
  flex: 1 1 calc(33.333% - 12rpx);
  min-width: 140rpx;
  padding: 24rpx 20rpx;
  background: var(--color-bg-paper);
  border: 1rpx solid var(--color-border-light);
  border-radius: var(--radius-sm);
  text-align: center;
  position: relative;
}

.milestone-done {
  background: var(--color-bg-noir);
  border-color: var(--color-gold-deep);
  box-shadow: inset 0 0 0 1rpx rgba(184, 153, 104, 0.4);
}
.milestone-done::before {
  content: '✦';
  position: absolute;
  top: -10rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 24rpx;
  height: 24rpx;
  font-size: 18rpx;
  color: var(--color-gold-light);
  background: var(--color-bg-primary);
  display: flex;
  align-items: center;
  justify-content: center;
}

.milestone-num {
  display: block;
  font-family: var(--font-family-serif);
  font-size: 44rpx;
  font-weight: var(--font-weight-light);
  color: var(--color-text-primary);
  letter-spacing: var(--tracking-tight);
  line-height: 1;
}
.milestone-done .milestone-num { color: var(--color-gold-light); }

.milestone-label {
  display: block;
  margin-top: 8rpx;
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
  letter-spacing: var(--tracking-wide);
}
.milestone-done .milestone-label { color: var(--color-gold-soft); }

/* ===== 详细统计入口 ===== */
.stats-link {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 32rpx 0 16rpx;
  text-align: center;
}
.stats-link-text {
  font-family: var(--font-family-serif);
  font-style: italic;
  font-size: var(--font-size-sm);
  letter-spacing: var(--tracking-wide);
  color: var(--color-gold-deep);
}
.stats-link-arrow {
  font-size: var(--font-size-base);
  color: var(--color-gold);
}

/* ===== 空态 ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
}

/* 扇形装饰（Art Deco 经典扇骨） */
.empty-fan {
  position: relative;
  width: 200rpx;
  height: 100rpx;
  margin-bottom: 40rpx;
}
.fan-ray {
  position: absolute;
  bottom: 0;
  left: 50%;
  width: 1rpx;
  height: 100rpx;
  background: var(--gradient-gold-line);
  transform-origin: bottom center;
}
.fan-ray:nth-child(1) { transform: translateX(-50%) rotate(-60deg); opacity: 0.5; }
.fan-ray:nth-child(2) { transform: translateX(-50%) rotate(-30deg); opacity: 0.7; }
.fan-ray:nth-child(3) { transform: translateX(-50%) rotate(0deg);   opacity: 1; }
.fan-ray:nth-child(4) { transform: translateX(-50%) rotate(30deg);  opacity: 0.7; }
.fan-ray:nth-child(5) { transform: translateX(-50%) rotate(60deg);  opacity: 0.5; }
.empty-fan::after {
  content: '';
  position: absolute;
  bottom: -4rpx;
  left: 50%;
  width: 8rpx;
  height: 8rpx;
  background: var(--gradient-gold);
  border-radius: 50%;
  transform: translateX(-50%);
}

.empty-title {
  margin-top: 32rpx;
  font-family: var(--font-family-serif);
  font-size: 72rpx;
  font-weight: var(--font-weight-light);
  color: var(--color-text-primary);
  letter-spacing: var(--tracking-wide);
}

.empty-text {
  margin-top: 16rpx;
  font-family: var(--font-family-serif);
  font-style: italic;
  font-size: var(--font-size-sm);
  color: var(--color-text-tertiary);
  letter-spacing: var(--tracking-wide);
}

.empty-btn {
  margin-top: 64rpx;
  padding: 24rpx 64rpx;
  background: var(--gradient-gold);
  border-radius: var(--radius-sm);
  box-shadow: var(--shadow-gold);
}

.empty-btn-text {
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-semibold);
  color: var(--color-bg-noir);
  letter-spacing: var(--tracking-wider);
  text-transform: uppercase;
}

/* ===== 习惯热力图 ===== */
.heatmap-section {
  margin-bottom: 48rpx;
}

.streak-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 48rpx;
  margin: 28rpx 0 32rpx;
}

.streak-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.streak-num {
  font-family: var(--font-family-serif);
  font-size: var(--font-size-xl);
  font-weight: var(--font-weight-light);
  color: var(--color-text-primary);
  letter-spacing: var(--tracking-tight);
  line-height: 1;
}

.streak-label {
  margin-top: 8rpx;
  font-size: var(--font-size-xs);
  color: var(--color-gold-deep);
  letter-spacing: var(--tracking-wider);
}

.streak-divider {
  width: 1rpx;
  height: 48rpx;
  background: var(--gradient-gold-line);
}

.heatmap-grid {
  display: flex;
  gap: 6rpx;
  justify-content: center;
  padding: 0 16rpx;
}

.heatmap-week {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.heatmap-cell {
  width: 40rpx;
  height: 40rpx;
  background: var(--color-bg-secondary);
  border-radius: 4rpx;
  border: 1rpx solid var(--color-border-light);
}

.heatmap-cell.heat-1 {
  background: var(--color-gold-soft);
  border-color: var(--color-gold-light);
}

.heatmap-cell.heat-2 {
  background: var(--color-gold);
  border-color: var(--color-gold-deep);
  box-shadow: 0 0 8rpx rgba(184, 153, 104, 0.3);
}

.heatmap-legend {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 8rpx;
  margin-top: 16rpx;
  padding-right: 16rpx;
}

.legend-text {
  font-size: 20rpx;
  color: var(--color-text-tertiary);
  letter-spacing: var(--tracking-wide);
}

.legend-cell {
  width: 24rpx;
  height: 24rpx;
}

/* ===== 每日术语卡片 ===== */
.term-card {
  margin-bottom: 56rpx;
}

.term-card-inner {
  position: relative;
  padding: 48rpx 36rpx 36rpx;
  background: var(--color-bg-paper);
  border: 1rpx solid var(--color-border-light);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-sm);
  overflow: hidden;
  text-align: center;
}

.term-card-inner::before {
  content: '';
  position: absolute;
  top: 0;
  left: 24rpx;
  right: 24rpx;
  height: 1rpx;
  background: var(--gradient-gold-line);
}

.term-category {
  display: block;
  font-size: 18rpx;
  letter-spacing: var(--tracking-widest);
  color: var(--color-gold-deep);
  text-transform: uppercase;
  font-weight: var(--font-weight-medium);
  margin-bottom: 20rpx;
}

.term-fr {
  display: block;
  font-family: var(--font-family-serif);
  font-style: italic;
  font-size: var(--font-size-2xl);
  font-weight: var(--font-weight-light);
  color: var(--color-text-primary);
  letter-spacing: var(--tracking-wider);
  line-height: 1.2;
}

.term-cn {
  display: block;
  margin-top: 12rpx;
  font-size: var(--font-size-lg);
  color: var(--color-text-primary);
  letter-spacing: var(--tracking-wider);
}

.term-pron {
  display: block;
  margin-top: 8rpx;
  font-family: var(--font-family-serif);
  font-style: italic;
  font-size: var(--font-size-sm);
  color: var(--color-text-tertiary);
  letter-spacing: var(--tracking-wide);
}

.term-divider {
  margin: 24rpx auto;
  width: 80rpx;
  height: 1rpx;
  background: var(--gradient-gold-line);
}

.term-explain {
  display: block;
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  letter-spacing: var(--tracking-wide);
  line-height: 1.7;
}

.term-action {
  margin-top: 28rpx;
  padding: 16rpx 0;
}

.term-action-text {
  font-size: var(--font-size-xs);
  color: var(--color-gold-deep);
  letter-spacing: var(--tracking-widest);
  font-weight: var(--font-weight-medium);
}

.term-learned {
  color: var(--color-gold-soft);
}
