<view class="page" wx:if="{{loaded}}">
  <!-- 用户信息卡片 -->
  <view class="profile-card" wx:if="{{profile}}">
    <image
      class="avatar"
      src="{{profile.avatarUrl || '/images/default-avatar.png'}}"
      mode="aspectFill"
    />
    <view class="profile-info">
      <text class="nickname">{{profile.nickname}}</text>
      <text class="dance-age">舞龄 {{profile.danceAge}} 个月</text>
    </view>
    <view class="edit-btn" bindtap="onEditProfile">
      <text class="edit-text">编辑</text>
    </view>
  </view>

  <!-- 目标 -->
  <view class="section" wx:if="{{profile.goal}}">
    <text class="section-label">学习目标</text>
    <text class="section-value">{{profile.goal}}</text>
  </view>

  <view class="section" wx:if="{{profile.intro}}">
    <text class="section-label">简介</text>
    <text class="section-value">{{profile.intro}}</text>
  </view>

  <view class="section">
    <text class="section-label">每周目标</text>
    <text class="section-value">{{profile.weeklyGoal || 3}} 节课</text>
  </view>

  <!-- 功能入口 -->
  <view class="menu-group">
    <view class="menu-item" bindtap="onSchedule">
      <text class="menu-label">个人课表</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <!-- 管理入口 -->
  <view class="menu-group">
    <view class="menu-item" bindtap="onManageStudios">
      <text class="menu-label">机构管理</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="onManageTeachers">
      <text class="menu-label">老师管理</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="onManageCourseTypes">
      <text class="menu-label">课型管理</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <!-- 数据管理 -->
  <view class="menu-group">
    <view class="menu-item" bindtap="onImportCSV">
      <text class="menu-label">导入数据（CSV）</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="onExportJSON">
      <text class="menu-label">一键导出（JSON）</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>
</view>
