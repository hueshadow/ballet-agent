<view class="page">
  <view class="page-header" wx:if="{{mode === 'init'}}">
    <text class="page-title">欢迎来到芭蕾管家</text>
    <text class="page-subtitle">填写你的个人档案，开启成长记录</text>
  </view>

  <!-- 头像 -->
  <view class="avatar-section">
    <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
      <image
        class="avatar-preview"
        src="{{avatarUrl || '/images/default-avatar.png'}}"
        mode="aspectFill"
      />
      <text class="avatar-hint">点击更换头像</text>
    </button>
  </view>

  <!-- 表单 -->
  <view class="form">
    <view class="form-item">
      <text class="form-label">昵称 *</text>
      <input
        class="form-input"
        type="nickname"
        placeholder="你的昵称"
        value="{{nickname}}"
        bindinput="onNicknameInput"
      />
    </view>

    <view class="form-item">
      <text class="form-label">舞龄（月数）</text>
      <input
        class="form-input"
        type="number"
        placeholder="例：60"
        value="{{danceAge}}"
        bindinput="onDanceAgeInput"
      />
    </view>

    <view class="form-item">
      <text class="form-label">每周课时目标</text>
      <input
        class="form-input"
        type="number"
        placeholder="默认 3 节"
        value="{{weeklyGoal}}"
        bindinput="onWeeklyGoalChange"
      />
    </view>

    <view class="form-item">
      <text class="form-label">学习目标</text>
      <input
        class="form-input"
        placeholder="例：完成考级 / 参加汇演 / 上足尖"
        value="{{goal}}"
        bindinput="onGoalInput"
      />
    </view>

    <view class="form-item">
      <text class="form-label">个人简介</text>
      <textarea
        class="form-textarea"
        placeholder="介绍一下自己..."
        value="{{intro}}"
        bindinput="onIntroInput"
        maxlength="200"
        auto-height
      />
    </view>
  </view>

  <button class="btn-primary save-btn" bindtap="onSave" disabled="{{saving}}">
    {{mode === 'init' ? '开始记录' : '保存'}}
  </button>
</view>
