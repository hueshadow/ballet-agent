@import '/styles/tokens.wxss';

.page { padding: 32rpx; }

/* 动作信息 */
.info-section { margin-bottom: 32rpx; }

.move-fr {
  display: block;
  font-size: var(--font-size-2xl);
  font-weight: var(--font-weight-semibold);
  letter-spacing: -1rpx;
}

.move-cn {
  display: block;
  font-size: var(--font-size-lg);
  color: var(--color-text-secondary);
  margin-top: 4rpx;
}

.move-pron {
  display: block;
  font-size: var(--font-size-sm);
  color: var(--color-text-tertiary);
  margin-top: 12rpx;
  font-style: italic;
}

.move-desc {
  display: block;
  font-size: var(--font-size-base);
  color: var(--color-text-secondary);
  margin-top: 16rpx;
  line-height: 1.6;
}

/* 操作按钮 */
.action-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.action-btn-primary {
  flex: 1;
  height: 80rpx;
  background: var(--color-accent);
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
}

.action-btn-text {
  font-size: var(--font-size-base);
  color: var(--color-text-inverse);
  font-weight: var(--font-weight-medium);
}

.action-btn-secondary {
  flex: 1;
  height: 80rpx;
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
}

.action-btn-text-dark {
  font-size: var(--font-size-base);
  color: var(--color-text-primary);
}

/* 对比 */
.compare-section { margin-bottom: 32rpx; }

.compare-hint {
  display: block;
  font-size: var(--font-size-sm);
  color: var(--color-text-tertiary);
  text-align: center;
  margin-bottom: 16rpx;
}

.compare-players {
  display: flex;
  gap: 12rpx;
}

.compare-player { flex: 1; }

.compare-video {
  width: 100%;
  height: 400rpx;
  border-radius: var(--radius-sm);
}

.compare-date {
  display: block;
  text-align: center;
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
  margin-top: 8rpx;
}

/* 时间线 */
.section-title {
  display: block;
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-semibold);
  margin-bottom: 20rpx;
}

.timeline-item {
  display: flex;
  gap: 20rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--color-border-light);
}

.timeline-item.selectable { background: var(--color-bg-secondary); border-radius: var(--radius-sm); padding: 16rpx; margin-bottom: 8rpx; border: none; }

.timeline-thumb-wrap { flex-shrink: 0; }

.timeline-thumb {
  width: 120rpx;
  height: 120rpx;
  border-radius: var(--radius-sm);
}

.timeline-thumb-empty {
  width: 120rpx;
  height: 120rpx;
  border-radius: var(--radius-sm);
  background: var(--color-bg-tertiary);
  display: flex;
  align-items: center;
  justify-content: center;
}

.play-icon {
  font-size: var(--font-size-lg);
  color: var(--color-text-tertiary);
}

.timeline-info { flex: 1; }

.timeline-date {
  display: block;
  font-size: var(--font-size-sm);
  color: var(--color-text-tertiary);
}

.timeline-stars {
  display: block;
  font-size: var(--font-size-sm);
  color: var(--color-text-primary);
  margin-top: 6rpx;
}

.timeline-notes {
  display: block;
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  margin-top: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.empty-hint {
  text-align: center;
  padding: 60rpx 0;
  font-size: var(--font-size-sm);
  color: var(--color-text-tertiary);
}
