@import '/styles/tokens.wxss';

.page { padding-bottom: 80rpx; }

/* 照片轮播 */
.photo-swiper {
  width: 100%;
  height: 500rpx;
}

.photo-full {
  width: 100%;
  height: 100%;
}

/* 基础信息 */
.info-section { padding: 32rpx; }

.info-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.info-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.info-date {
  font-size: var(--font-size-sm);
  color: var(--color-text-tertiary);
}

.info-emoji { font-size: var(--font-size-lg); }

.info-source {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
  padding: 4rpx 16rpx;
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-full);
}

.info-studio {
  display: block;
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
  margin-bottom: 12rpx;
}

.info-meta {
  display: flex;
  gap: 16rpx;
}

.meta-item {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  padding: 4rpx 16rpx;
  background: var(--color-bg-secondary);
  border-radius: var(--radius-full);
}

/* 评分 */
.rating-section {
  padding: 0 32rpx 24rpx;
}

.rating-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.rating-label {
  font-size: var(--font-size-sm);
  color: var(--color-text-tertiary);
  width: 120rpx;
}

.rating-stars {
  font-size: var(--font-size-base);
  color: var(--color-text-primary);
}

/* 标签 */
.tags-section {
  padding: 0 32rpx 24rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  padding: 8rpx 20rpx;
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-full);
}

/* 笔记 */
.notes-section {
  padding: 0 32rpx 32rpx;
}

.notes-label {
  display: block;
  font-size: var(--font-size-sm);
  color: var(--color-text-tertiary);
  margin-bottom: 12rpx;
}

.notes-content {
  display: block;
  font-size: var(--font-size-base);
  color: var(--color-text-primary);
  line-height: 1.6;
}

/* 操作 */
.actions { padding: 0 32rpx; }

.action-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.action-btn { flex: 1; }

.sign-btn { margin-bottom: 24rpx; }

.delete-link {
  text-align: center;
  padding: 24rpx 0;
}

.delete-text {
  font-size: var(--font-size-sm);
  color: var(--color-error);
}
