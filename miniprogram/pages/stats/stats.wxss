@import '/styles/tokens.wxss';

.page { padding: 32rpx; }

.chart-section {
  margin-bottom: 48rpx;
}

.chart-title {
  display: block;
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
  margin-bottom: 24rpx;
}

/* 竖向柱状图（月度趋势） */
.bar-chart {
  display: flex;
  align-items: flex-end;
  height: 300rpx;
  gap: 4rpx;
  padding-top: 40rpx;
}

.bar-col {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  height: 100%;
}

.bar-value {
  font-size: 18rpx;
  color: var(--color-text-tertiary);
  margin-bottom: 4rpx;
}

.bar-fill-wrap {
  flex: 1;
  width: 100%;
  display: flex;
  align-items: flex-end;
}

.bar-fill {
  width: 100%;
  background: var(--color-accent);
  border-radius: 4rpx 4rpx 0 0;
  min-height: 4rpx;
  transition: height 0.5s var(--ease-out);
}

.bar-label {
  font-size: 18rpx;
  color: var(--color-text-tertiary);
  margin-top: 8rpx;
}

/* 横向条形图（分布） */
.h-bar-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.h-bar-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.h-bar-name {
  font-size: var(--font-size-sm);
  color: var(--color-text-primary);
  width: 140rpx;
  flex-shrink: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.h-bar-track {
  flex: 1;
  height: 20rpx;
  background: var(--color-bg-secondary);
  border-radius: var(--radius-full);
  overflow: hidden;
}

.h-bar-fill {
  height: 100%;
  background: var(--color-accent);
  border-radius: var(--radius-full);
  transition: width 0.5s var(--ease-out);
}

.h-bar-count {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
  width: 140rpx;
  flex-shrink: 0;
  text-align: right;
}

/* 空态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
}

.empty-text {
  font-size: var(--font-size-base);
  color: var(--color-text-secondary);
}

.empty-hint {
  font-size: var(--font-size-sm);
  color: var(--color-text-tertiary);
  margin-top: 12rpx;
}
