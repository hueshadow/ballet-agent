@import '/styles/tokens.wxss';

.page { padding: 32rpx; }

.header-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.page-title {
  font-size: var(--font-size-xl);
  font-weight: var(--font-weight-semibold);
}

.add-btn {
  padding: 12rpx 28rpx;
  background: var(--color-accent);
  border-radius: var(--radius-full);
}

.add-text {
  font-size: var(--font-size-sm);
  color: var(--color-text-inverse);
}

.filter-row { margin-bottom: 24rpx; }

.filter-btn {
  display: inline-block;
  padding: 10rpx 24rpx;
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-full);
}

.filter-text {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
}

.list-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 0;
  border-bottom: 1rpx solid var(--color-border-light);
}

.item-info { flex: 1; }

.item-name {
  display: block;
  font-size: var(--font-size-base);
  color: var(--color-text-primary);
}

.item-sub {
  display: block;
  font-size: var(--font-size-sm);
  color: var(--color-text-tertiary);
  margin-top: 4rpx;
}

.item-actions { display: flex; gap: 24rpx; }
.action-edit { font-size: var(--font-size-sm); color: var(--color-text-secondary); }
.action-delete { font-size: var(--font-size-sm); color: var(--color-error); }

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
}
.empty-text { font-size: var(--font-size-base); color: var(--color-text-secondary); }
.empty-hint { font-size: var(--font-size-sm); color: var(--color-text-tertiary); margin-top: 12rpx; }
