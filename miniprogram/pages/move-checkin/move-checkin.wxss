@import '/styles/tokens.wxss';

.page { padding: 32rpx; }

.page-title {
  display: block;
  font-size: var(--font-size-xl);
  font-weight: var(--font-weight-semibold);
}

.page-hint {
  display: block;
  font-size: var(--font-size-sm);
  color: var(--color-text-tertiary);
  margin-top: 8rpx;
  margin-bottom: 32rpx;
}

/* 视频 */
.video-section { margin-bottom: 32rpx; }

.video-preview {
  width: 100%;
  height: 500rpx;
  border-radius: var(--radius-md);
}

.video-placeholder {
  width: 100%;
  height: 400rpx;
  background: var(--color-bg-secondary);
  border-radius: var(--radius-md);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}

.placeholder-icon { font-size: 80rpx; }

.placeholder-text {
  font-size: var(--font-size-sm);
  color: var(--color-text-tertiary);
}

.change-video {
  text-align: center;
  margin-top: 16rpx;
}

.change-text {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
}

/* 表单 */
.form-item { margin-bottom: 28rpx; }

.form-label {
  display: block;
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  margin-bottom: 12rpx;
}

.star-row { display: flex; gap: 16rpx; }
.star { font-size: 52rpx; color: var(--color-border); }
.star-filled { color: var(--color-text-primary); }

.form-textarea {
  width: 100%;
  min-height: 120rpx;
  padding: 20rpx 24rpx;
  font-size: var(--font-size-base);
  background: var(--color-bg-secondary);
  border-radius: var(--radius-md);
  box-sizing: border-box;
}
